{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tomato",
  "scopeName": "source.tomato",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#numbers" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#list-punctuation" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tomato",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tomato",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tomato",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tomato",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tomato",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tomato",
          "match": "\\b(assign|print|input|into|where|do|loop|function|return|call|import|export|var|list)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.tomato",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "null": {
      "patterns": [
        {
          "name": "constant.language.null.tomato",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tomato",
          "match": "\\b-?\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.tomato",
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.control.tomato" },
            "2": { "name": "entity.name.function.tomato" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.tomato",
          "match": "\\b(call)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "keyword.control.tomato" },
            "2": { "name": "entity.name.function.tomato" }
          }
        }
      ]
    },
    "list-punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.brackets.begin.tomato",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.tomato",
          "match": "\\]"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.tomato",
          "match": "==|!=|<=|>=|[+\\-*/<>]=?|="
        }
      ]
    }
  }
}
