{
  "name": "tomato-language-support",
  "displayName": "Tomato Language",
  "description": "Syntax highlighting support for the cursed Tomato programming language.",
  "version": "0.0.1",
  "publisher": "magentapenguin",
  "license": "MIT",
  "keywords": [
    "tomato",
    "language",
    "syntax",
    "highlighting"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/magentapenugin/tomato.git"
  },
  "bugs": {
    "url": "https://github.com/magentapenugin/tomato/issues"
  },
  "homepage": "https://github.com/magentapenguin/tomato/tree/master/vscode-extension#readme",
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tomato",
        "aliases": [
          "Tomato",
          "tomato"
        ],
        "extensions": [
          ".tomato"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tomato",
        "scopeName": "source.tomato",
        "path": "./syntaxes/tomato.tmLanguage.json"
      }
    ]
  }
}
